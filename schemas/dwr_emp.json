{
  "survey": "DWR-DEMP (BSA)",
  "description": "Data from BSA lab for DWR YDiscrete Environmental Monitoring Program. Contains primary and continuation rows due to multiple measurement data types; all information is not related to measurements is blank in continuation rows.",
  "code": "DWR-EMP",
  "sampling_event_cols": ["Date", "Station", "Taxon"],
  "presets": ["PESP", "Survey"],
  "subset_cols": {
    "PESP": ["Date", "Time", "Station", "SampleMethod", "SampleDepth", "OrigTaxon", "Taxon", "Kingdom", "Phylum", "Class", "AlgalGroup", "Genus", "Species", "Lab", "Cells_per_mL", "Units_per_mL", "Biovolume_per_mL", "GALD", "PhytoForm", "QualityCheck", "Debris", "Notes"],
    "Survey": ["Date", "Time", "Station", "SampleMethod", "SampleDepth", "OrigTaxon", "Taxon", "Kingdom", "Phylum", "Class", "AlgalGroup", "Genus", "Species", "Lab", "Cells_per_mL", "Units_per_mL", "Biovolume_per_mL", "GALD", "PhytoForm", "QualityCheck", "Debris", "Notes"]
  },
  "combine_key_cols": ["Date", "Station"],
  "combine_measurement_cols": ["Biovolume_per_mL", "Units_per_mL", "Cells_per_mL"],
  "metadata_columns": {
    "PESP":   ["SampleDepth", "Lab", "SampleMethod"],
    "Survey": ["SampleDepth"]
  },
  "comment_col_defaults": {
    "PESP":   ["QC", "Debris", "Notes"],
    "Survey": ["QC", "Debris", "Notes"]
  },
  "steps": {
    "standardize_unknowns": {
      "PESP": { "applies": true, "std_sp": true, "std_suffix": true },
      "Survey": { "applies": true, "std_sp": true, "std_suffix": false }
    },
    "higher_lvl_taxa": {
      "PESP": { "applies": true, "std_type": "pesp" },
      "Survey": { "applies": true, "std_type": "program" }
    }
  },
  "sheet": "Sample Info",
  "mapping": {
    "Station":        "StationCode",
    "Date":           "SampleDate",
    "Time":           "SampleTime",
    "FullCode":       "Full Code",
    "Depth":          "Depth (m)",
    "VolReceived":    "Volume Received (mL)",
    "VolAnalyzed":    "Volume Analyzed (mL)",
    "PctCounted":     "Percent of Sample Counted",
    "FOV":            "Field-of-view (mm²)",
    "SlideArea":      "Slide/ Chamber Area (mm²)",
    "AreaCounted":    "Area Counted",
    "FieldCount":     "Number of Fields Counted",
    "Factor":         "Factor",
    "TIN":            "BSA_TIN",
    "Taxon":          "Taxon",
    "AlgaeType":      "Diatom/SoftBody",
    "Genus":          "Genus",
    "Species":        "Species",
    "Synonym":        "Synonym",
    "UnitAbundance":  "Unit Abundance (# of Natural Units)",
    "CellCount":      "Total Number of Cells",
    "GALD":           "GALD 1",
    "GALD2":          "GALD 2",
    "GALD3":          "GALD 3",
    "GroupCode":      "Colony/Filament/Individual Group Code",
    "BSAID":          "BSA#",
    "Taxonomist":     "Taxonomist",
    "Comments":       "Comments",
    "Shape":          "Shape",
    "Biovolume1":     "Biovolume 1",
    "Biovolume2":     "Biovolume 2",
    "Biovolume3":     "Biovolume 3",
    "Biovolume4":     "Biovolume 4",
    "Biovolume5":     "Biovolume 5",
    "Biovolume6":     "Biovolume 6",
    "Biovolume7":     "Biovolume 7",
    "Biovolume8":     "Biovolume 8",
    "Biovolume9":     "Biovolume 9",
    "Biovolume10":    "Biovolume 10",
    "Dimension":      "Dimension",
